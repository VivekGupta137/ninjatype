---
import AnalyticsContainer from "@/components/analytics/AnalyticsContainer.astro";
import ConfigToolbar from "@/components/ConfigToolbar";
import Footer from "@/components/Footer";
import Header from "@/components/Header.astro";
import OnlineAnalyticsContainer from "@/components/online/OnlineAnalyticsContainer";
import OnlineKeyboardContainer from "@/components/online/OnlineKeyboardContainer";
import FAQ from "@/components/seo/FAQ";
import BottomToolbar from "@/components/toolbar/BottomToolbar";
import { onlinePageFAQs } from "@/constants/faq";
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
    createSchemaGraph,
    getFAQPageSchema,
    getWebPageSchema,
} from "@/lib/schema-templates";

const canonicalURL = new URL("/online", Astro.site || Astro.url.origin).href;
const schemaMarkup = createSchemaGraph(
    getWebPageSchema({
        url: canonicalURL,
        name: "NinjaType Online Typing Race",
        description:
            "Join NinjaType Online mode for a live typing race with real-time rank updates, WPM tracking, accuracy insights, and penalty-adjusted results.",
    }),
    getFAQPageSchema(onlinePageFAQs),
);
---

<BaseLayout
    title="Online Typing Race - Live Rank, WPM, Accuracy & Results | NinjaType"
    description="Practice on NinjaType Online mode with live typing race analytics, real-time rank updates, WPM tracking, accuracy insights, and penalty-adjusted finish times."
    canonical={canonicalURL}
>
    <script
        type="application/ld+json"
        set:html={JSON.stringify(schemaMarkup)}
    />

    <div id="body-container">
        <Header />

        <main id="main-content">
            <div id="main-container" class="mb-2">
                <!-- <ConfigToolbar client:load /> -->
                <OnlineKeyboardContainer client:load />
            </div>
            <div class="mb-2">
                <OnlineAnalyticsContainer client:load />
            </div>
            <BottomToolbar client:load />
            <FAQ faqs={onlinePageFAQs} client:load />
        </main>
        <Footer />
    </div>
</BaseLayout>
