---
import ReactLoaded from "./common/ReactLoaded";
import LiveUserCounter from "./LiveUserCounter";
---

<!-- <ReactLoaded client:only /> -->
<header>
    <div class="header-container">
        <div id="logo">
            <a href="/">
                <h1 id="logo-text" class="bagel-fat-one-regular">Ninja Type</h1>
            </a>
        </div>
        <div>
            <div class="header-buttons">
                <a href="/online/" class="btn">
                    <i class="material-icons">public</i> Online
                </a>
                <a href="/learn/" class="icon-button">
                    <i class="material-icons">school</i>
                </a>
                <a href="/history/" class="icon-button">
                    <i class="material-icons">history</i>
                </a>

                <a href="/settings/" class="btn">
                    <i class="material-icons">settings</i>
                </a>
            </div>
            <div style="position: fixed; top: 23px; right: 10px;">
                <LiveUserCounter client:load />
            </div>
        </div>
    </div>
</header>
